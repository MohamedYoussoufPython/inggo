# ─── Android local.properties ───
# Copy this file to local.properties and fill in your values.
# This file is git-ignored and should NEVER be committed.

# Flutter SDK path (auto-set by flutter pub get)
flutter.sdk=/path/to/flutter/sdk

# Google Maps API Key (required for Android maps)
# Get your key from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
